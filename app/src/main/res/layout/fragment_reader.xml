<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reader_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 페이지 캔버스 — 상/하 status strip (각 32dp) 만 padding 으로 비우고,
         나머진 전부 텍스트. top_menu_row / bottom_bar 는 overlay. -->
    <com.example.minseo3.PageView
        android:id="@+id/page_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_reader_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:textColor="#888888"
        android:textSize="14sp"
        android:text="읽을 책을 선택하세요"
        android:visibility="gone" />

    <!-- 상단: 항상 보이는 status strip (페이지/시계) — 32dp -->
    <LinearLayout
        android:id="@+id/top_status_strip"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_status_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:text="1 / 1  (0%)" />

        <TextClock
            android:id="@+id/tv_status_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:format12Hour="a h:mm"
            android:format24Hour="HH:mm" />
    </LinearLayout>

    <!-- 상단: 메뉴 (설정/NAS) — hideable, 중앙 tap 시 overlay. status strip 바로 아래에 뜸. -->
    <LinearLayout
        android:id="@+id/top_menu_row"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:layout_marginTop="32dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/menu_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="설정" />

        <TextView
            android:id="@+id/menu_nas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="NAS" />
    </LinearLayout>

    <!-- 하단: 컨트롤 바 (seekbar + 버튼) — hideable, 중앙 tap 시 overlay.
         파일명 strip 바로 위에 뜸. -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="8dp"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_bookmarks"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_bookmark_star_outline"
                android:contentDescription="@string/bookmarks_title" />

            <ImageButton
                android:id="@+id/btn_tts"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:tint="#FFFFFF"
                android:contentDescription="TTS" />

            <TextView
                android:id="@+id/tv_page_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:text="1 / 1" />

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFFFFF"
                android:contentDescription="@string/back_to_list" />

        </LinearLayout>
    </LinearLayout>

    <!-- 하단: 파일명 strip (항상 보임, 32dp, 상단 strip 과 대칭). -->
    <LinearLayout
        android:id="@+id/bottom_filename_strip"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="middle"
            android:text="" />
    </LinearLayout>

</FrameLayout>
