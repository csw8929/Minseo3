<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="0dp"
    android:paddingBottom="20dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- 드래그 핸들 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="18dp"
        android:background="#33000000"
        android:backgroundTint="?android:attr/textColorPrimary"
        android:alpha="0.3" />

    <!-- Font size -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="글자 크기"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="가"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seek_font_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="가"
            android:textSize="22sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_font_size"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="17"
            android:textSize="13sp"
            android:gravity="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 굵은 글씨체 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="굵은 글씨체"
            android:textStyle="bold"
            android:textSize="15sp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Background theme -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="배경 색깔"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <View android:id="@+id/btn_theme_white"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/theme_circle_white" />

        <View android:id="@+id/btn_theme_sepia"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/theme_circle_sepia" />

        <View android:id="@+id/btn_theme_gray"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/theme_circle_gray" />

        <View android:id="@+id/btn_theme_dark"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/theme_circle_dark" />

        <View android:id="@+id/btn_theme_black"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="@drawable/theme_circle_black" />
    </LinearLayout>

    <!-- 탭 영역 좌/우 스위칭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="탭기능 스위칭"
            android:textStyle="bold"
            android:textSize="15sp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_tap_swap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="켜면 왼쪽 탭이 다음 페이지, 오른쪽 탭이 이전 페이지로 바뀝니다."
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary" />

    <!-- ── TTS 음성 ──────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="18dp"
        android:background="?android:attr/textColorPrimary"
        android:alpha="0.12" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="읽기 속도"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="느리게"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seek_tts_rate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="빠르게"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_tts_rate"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="1.0x"
            android:textSize="13sp"
            android:gravity="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_tts_engine_settings"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="음성 엔진 변경"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="시스템 설정에서 더 좋은 한국어 TTS 엔진(Samsung / Google / Naver 등)을 설치·선택할 수 있습니다."
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary" />


</LinearLayout>
</androidx.core.widget.NestedScrollView>
