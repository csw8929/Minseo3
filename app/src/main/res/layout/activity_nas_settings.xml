<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NAS 연결 설정"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Enable toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/sw_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NAS 동기화 사용"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="주소 (예: 192.168.1.100 또는 myhost.synology.me)"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/et_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:hint="host"
            android:autofillHints="off"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="포트 (기본 5000)"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/et_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="5000"
            android:autofillHints="off"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="사용자 이름"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/et_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:autofillHints="username"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="비밀번호"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/et_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="공유 폴더 경로"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/et_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="/소설/.minseo/"
            android:autofillHints="off"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="※ 실제 동기화는 다음 업데이트에서 활성화됩니다."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
